<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <title>Password Reset</title>
</head>
<body style="font-family: Arial, sans-serif; background: #f7f8fa; padding: 24px;">
<table style="max-width: 640px; margin: 0 auto; background: #fff; border: 1px solid #eceef3; border-radius: 8px;">
    <tr>
        <td style="padding: 24px;">
            <h2 style="margin-top: 0; color: #111827;">Reset your password</h2>
            <p style="color: #374151;">Hi {{ displayName }},</p>
            <p style="color: #374151;">
                We received a request to reset your account password.
                Click the button below to set a new password.
            </p>
            <p style="margin: 24px 0;">
                <a href="{{ resetLink }}"
                   style="display: inline-block; background: #1746e0; color: #ffffff; text-decoration: none; padding: 12px 18px; border-radius: 6px;">
                    Reset password
                </a>
            </p>
            <p style="color: #6b7280;">
                This link will expire shortly for security reasons.
            </p>
            <p style="color: #6b7280;">
                If you did not request a password reset, you can ignore this email.
            </p>
            <p style="color: #6b7280;">
                Support: {{ supportEmail }}
            </p>
        </td>
    </tr>
</table>
</body>
</html>