<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <title>Verify Email Change</title>
</head>
<body style="font-family: Arial, sans-serif; background: #f7f8fa; padding: 24px;">
<table style="max-width: 640px; margin: 0 auto; background: #fff; border: 1px solid #eceef3; border-radius: 8px;">
    <tr>
        <td style="padding: 24px;">
            <h2 style="margin-top: 0; color: #111827;">Welcome!</h2>
            <p style="color: #374151;">Hi {{ displayName }},</p>
            <p style="color: #374151;">
                To confirm your account, click the button below.
            </p>
            <p style="margin: 24px 0;">
                <a href="{{ verifyLink }}"
                   style="display: inline-block; background: #1746e0; color: #ffffff; text-decoration: none; padding: 12px 18px; border-radius: 6px;">
                    Confirm account
                </a>
            </p>
            <p style="color: #6b7280;">
                If you did not initiate this sign-up request, just ignore this email. We apologize for any inconvenience.
            </p>
            <p style="color: #6b7280;">
                Support: {{ supportEmail }}
            </p>
        </td>
    </tr>
</table>
</body>
</html>
